<!DOCTYPE html>
<html lang="en">
<head>
  
  <meta charset="UTF-8">
  <title>Explore | PYQ Hub</title>
  <link rel="icon" href="/images/logo2.png" type="image/png">
  
  <script src="https://cdn.tailwindcss.com"></script>

  
  <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-gray-100">

<%- include("partials/navbar") %>


<section class="text-center mt-10">
  <h1 class="text-4xl font-bold text-blue-600">
    Explore Question Papers
  </h1>
  <p class="text-gray-500 mt-2">
    Search, filter and download previous year papers easily
  </p>
</section>


<form action="/explore" method="GET" 
      class="max-w-5xl mx-auto mt-8 flex flex-wrap items-center justify-center gap-3">

  
  <input type="text" name="q"
    placeholder="Search by title or subject"
    value="<%= typeof q !== 'undefined' ? q : '' %>"
    class="px-4 py-2 border rounded-lg w-64">

  
  <select name="examType" class="px-4 py-2 border rounded-lg">
    <option value="">All Exams</option>
    <option value="JEE">JEE</option>
    <option value="NEET">NEET</option>
    <option value="GATE">GATE</option>
    <option value="CAT">CAT</option>
    <option value="Semester">Semester Exam</option>
  </select>

  
  <input type="number" name="year" placeholder="Year"
    class="px-4 py-2 border rounded-lg w-32">

  
  <button type="submit"
    class="bg-blue-600 text-white px-5 py-2 rounded-lg hover:bg-blue-700">
    Search
  </button>

</form>


<div class="max-w-6xl mx-auto mt-10 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

  <% if(papers.length === 0){ %>

    <div class="col-span-3 text-center text-gray-500">
      No papers found 📂
    </div>

  <% } %>

  <% papers.forEach(paper => { %>

    <div class="bg-white p-5 rounded-xl shadow hover:shadow-lg transition">

      <h3 class="font-semibold text-lg"><%= paper.title %></h3>
      <p class="text-sm text-gray-500"><%= paper.subject %></p>

      <div class="mt-2 text-xs text-gray-400 flex justify-between">
        <span><%= paper.examType %></span>
        <span><%= paper.year %></span>
      </div>

      <div class="mt-4 flex justify-between">
        <a href="/uploads/<%= paper.filename %>" target="_blank"
           class="text-green-600 text-sm">View</a>

        <a href="/download/<%= paper._id %>"
           class="text-blue-600 text-sm">Download</a>
      </div>

    </div>

  <% }) %>

</div>

<%- include("partials/footer") %>

</body>
</html>