<!DOCTYPE html>
<html>
<head>
  <title>Upload Paper</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 flex justify-center items-center h-screen">

  <form action="/upload" method="POST" enctype="multipart/form-data"
        class="bg-white p-6 rounded shadow w-96">

    <h2 class="text-xl font-bold mb-4">Upload Paper</h2>

    <input type="text" name="title" placeholder="Title"
           class="w-full mb-3 p-2 border rounded" required>

    <input type="text" name="subject" placeholder="Subject"
           class="w-full mb-3 p-2 border rounded" required>

    <input type="text" name="examType" placeholder="Exam Type"
           class="w-full mb-3 p-2 border rounded" required>

    <input type="number" name="year" placeholder="Year"
           class="w-full mb-3 p-2 border rounded" required>

    <input type="file" name="file"
           class="w-full mb-3" required>

    <button type="submit"
            class="w-full bg-blue-600 text-white p-2 rounded">
      Upload
    </button>

  </form>

</body>
</html>