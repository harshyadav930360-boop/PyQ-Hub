<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Upload Paper | PYQ Hub</title>

  <!-- Tailwind for modern UI -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Your CSS (kept) -->
  <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-gray-100">

<%- include("partials/navbar") %>

<div class="max-w-4xl mx-auto mt-10">

  <!-- HEADER -->
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold">Upload Paper</h1>
      <p class="text-gray-500">
        Help your peers by sharing previous year question papers.
      </p>
    </div>

    <!-- <button class="bg-gray-200 px-4 py-2 rounded">
      View Guidelines
    </button> -->
  </div>

  <!-- CARD -->
  <div class="bg-white p-8 rounded-xl shadow">

    <form action="/upload" method="POST" enctype="multipart/form-data" class="space-y-6">

      <!-- PAPER DETAILS -->
      <div>
        <h2 class="text-lg font-semibold mb-4">Paper Details</h2>

        <div class="grid grid-cols-2 gap-4">

          <div>
            <label class="text-sm font-medium">Subject Name</label>
            <input type="text" name="subject"
              placeholder="e.g. Data Structures"
              class="w-full mt-1 p-3 border rounded-lg" required>
          </div>

          <div>
            <label class="text-sm font-medium">Academic Year</label>
            <input type="number" name="year"
              placeholder="e.g. 2023"
              class="w-full mt-1 p-3 border rounded-lg" required>
          </div>

        </div>

        <input type="text" name="title"
          placeholder="Collage or Competative Exam"
          class="w-full mt-4 p-3 border rounded-lg" required>

        <input type="text" name="examType"
          placeholder="Exam Type"
          class="w-full mt-4 p-3 border rounded-lg" required>
      </div>

      <!-- FILE UPLOAD -->
      <div>
        <h2 class="text-lg font-semibold mb-4">Upload File</h2>

        <div class="border-2 border-dashed p-8 text-center rounded-lg">
          <p class="text-gray-500 mb-2">Upload PDF or Image</p>
          <input type="file" name="file" required>
        </div>
      </div>

      <!-- BUTTON -->
      <div class="flex justify-end">
        <button type="submit"
          class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700">
          Upload Paper
        </button>
      </div>

    </form>

  </div>

</div>

<%- include("partials/footer") %>

</body>
</html>