<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Profile | PYQ Hub</title>

  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/style.css" />
</head>

<body class="bg-gray-100 flex flex-col min-h-screen">

<%- include("partials/navbar") %>

<div class="flex-1 p-6">
  <div class="flex gap-8 items-start">

  <!-- 🔥 LEFT SIDEBAR -->
  <div class="w-80 bg-white rounded-2xl p-6 shadow-md">

    <!-- AVATAR WITH UPLOAD -->
    <div class="relative w-28 h-28 mx-auto group">

      <img src="<%= user.avatar || '/images/default.png' %>"
           class="w-28 h-28 rounded-full object-cover border-4 border-blue-500 shadow">

      <!-- OVERLAY -->
      <form action="/upload-avatar" method="POST" enctype="multipart/form-data"
            class="absolute inset-0 bg-black bg-opacity-50 rounded-full flex items-center justify-center 
                   opacity-0 group-hover:opacity-100 transition">

        <input type="file" name="avatar" accept="image/*"
               onchange="this.form.submit()"
               class="absolute inset-0 opacity-0 cursor-pointer">

        <span class="text-white text-xs">Change</span>
      </form>
    </div>

    <!-- USER INFO -->
    <div class="text-center mt-4">
      <h2 class="text-xl font-bold"><%= user.username %></h2>

      <p class="text-sm font-semibold uppercase mt-1
        <%= user.role === 'admin' ? 'text-red-500' :
            user.role === 'professor' ? 'text-purple-500' :
            'text-blue-600' %>">
        <%= user.role %>
      </p>

      <p class="text-gray-500 text-sm"><%= user.email || "No email" %></p>
    </div>

    <!-- STATS -->
    <div class="mt-6 grid grid-cols-2 gap-4">
      <div class="bg-gray-100 p-4 rounded-xl text-center">
        <h2 class="text-blue-600 font-bold text-lg"><%= papers.length %></h2>
        <p class="text-xs text-gray-500">Uploads</p>
      </div>

      <div class="bg-gray-100 p-4 rounded-xl text-center">
        <h2 class="text-blue-600 font-bold text-lg">
          <%= papers.reduce((acc, p) => acc + (p.downloads || 0), 0) %>
        </h2>
        <p class="text-xs text-gray-500">Downloads</p>
      </div>
    </div>

    <!-- BUTTON -->
    <% if (user.role === "admin" || user.role === "professor") { %>

      <a href="/upload"
         class="block mt-6 bg-blue-600 text-white text-center py-2 rounded">
         Upload Paper
      </a>

      <% if (user.role === "admin") { %>
        <a href="/admin" 
           class="block mt-3 bg-red-600 text-white text-center py-2 rounded hover:bg-red-700 transition">
           Admin Dashboard
        </a>
      <% } %>

    <% } else { %>
    
      <button onclick="alert('Students are not allowed to upload papers')"
         class="block mt-6 bg-gray-400 text-white text-center py-2 rounded w-full">
         Upload Paper
      </button>
    
    <% } %>

  </div>

  <!-- 🔥 RIGHT SIDE -->
  <div class="flex-1">

    <!-- HEADER -->
    <div class="mb-6">
      <h1 class="text-2xl font-bold">My Uploaded Papers</h1>
      <p class="text-gray-500 text-sm">Manage your uploaded resources</p>
    </div>

    <!-- GRID -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">

      <% if(papers.length === 0){ %>

        <div class="col-span-3 text-center p-12 bg-white rounded-xl shadow">
          <p class="text-gray-500">No papers uploaded yet 📂</p>
        </div>

      <% } %>

      <% papers.forEach(paper => { %>

        <div class="bg-white p-5 rounded-xl shadow hover:shadow-lg transition">

          <h3 class="font-semibold text-lg"><%= paper.title %></h3>
          <p class="text-sm text-gray-500"><%= paper.subject %></p>

          <div class="mt-3 flex justify-between text-xs text-gray-400">
            <span><%= paper.examType %></span>
            <span><%= paper.year %></span>
          </div>

          <!-- ACTIONS -->
          <div class="mt-4 flex justify-between items-center">

            <a href="/uploads/<%= paper.filename %>"
               target="_blank"
               class="text-green-600 text-sm font-medium hover:underline">
                View
            </a>

            <a href="/download/<%= paper._id %>"
               class="text-blue-600 text-sm font-medium hover:underline">
                Download
            </a>

          </div>

        </div>

      <% }) %>

    </div>

  </div>

</div>
</div>
<%- include("partials/footer") %>

</body>
</html>